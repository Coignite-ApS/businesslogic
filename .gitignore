# =============================================================================
# BusinessLogic Platform — .gitignore
# =============================================================================

# ── Secrets & Environment ────────────────────────────────────────────
# NEVER commit .env files with real secrets
infrastructure/docker/.env
services/*/.env
.env
.env.local
.env.production

# ── Dependencies ─────────────────────────────────────────────────────
node_modules/
.pnp.*
.yarn/

# ── Build outputs ────────────────────────────────────────────────────
dist/
build/
target/
*.js.map
*.d.ts

# ── Rust ─────────────────────────────────────────────────────────────
services/flow/target/
packages/bl-common/target/
Cargo.lock

# ── Go ───────────────────────────────────────────────────────────────
services/gateway/gateway

# ── IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Docker ───────────────────────────────────────────────────────────
*.log
docker-compose.override.yml

# ── OS ───────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store

# ── Claude Code (local settings only — .claude/settings.json IS committed) ──
.claude/settings.local.json

# ── Git Worktrees ───────────────────────────────────────────────────
.worktrees/

# ── Database Snapshots (large binary, keep local only) ───────────
infrastructure/db-snapshots/*.sql.gz

# ── Test artifacts ───────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Legacy implementation (reference only, has its own git history) ──
# legacy-implementation/ is tracked but its internal .git dirs are not
legacy-implementation/*/.git
legacy-implementation/*/node_modules
legacy-implementation/*/target
legacy-implementation/
