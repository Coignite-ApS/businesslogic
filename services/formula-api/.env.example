# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=warn

# Worker pool
POOL_SIZE=0
REQUEST_TIMEOUT_MS=10000

# Engine (hyperformula | bl-excel | both)
ENGINE=hyperformula

# Locale
DEFAULT_LOCALE=enUS

# Redis (optional)
REDIS_URL=
CACHE_TTL_SECONDS=3600
CACHE_MAX_MEMORY_ITEMS=50000

# Backpressure
MAX_QUEUE_DEPTH=0
MAX_HEAP_USED_BYTES=0
MAX_EVENT_LOOP_DELAY_MS=500

# Auth (protects calculator CRUD, list, parse endpoints)
ADMIN_TOKEN=

# Upload
MAX_UPLOAD_SIZE=5MB

# Calculators
CALCULATOR_TTL_SECONDS=1800
CALCULATOR_REDIS_TTL_SECONDS=86400
CALCULATOR_RESULT_TTL_SECONDS=3600
MAX_CALCULATORS_PER_WORKER=10
MAX_CALCULATORS=100

# Admin API (base URL, no trailing slash — stats + recipe persistence)
ADMIN_API_URL=
ADMIN_API_KEY=
STATS_FLUSH_INTERVAL_MS=10000
STATS_MAX_BATCH=1000
