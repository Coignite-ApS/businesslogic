# Server
PORT=8080
LOG_LEVEL=info

# Data stores
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://directus:directus@localhost:5432/directus

# Backend services
AI_API_URL=http://localhost:3200
FORMULA_API_URL=http://localhost:3000
FLOW_TRIGGER_URL=http://localhost:3100
CMS_URL=http://localhost:8055

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=30s

# Cache TTLs
KEY_CACHE_TTL=10m
NEGATIVE_CACHE_TTL=1m

# Health check
HEALTH_CHECK_INTERVAL=10s
