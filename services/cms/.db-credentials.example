# =============================================================================
# Database Credentials for Remote Sync
# =============================================================================
# Copy this file to .db-credentials and fill in your actual values:
#   cp .db-credentials.example .db-credentials
#
# Get connection details from:
#   - Terraform output
#   - DigitalOcean Database dashboard
#   - Your team's secrets manager
# =============================================================================

# -----------------------------------------------------------------------------
# Development Environment
# -----------------------------------------------------------------------------
DEV_DB_HOST="your-dev-db-host.db.ondigitalocean.com"
DEV_DB_PORT="25060"
DEV_DB_NAME="directus"
DEV_DB_USER="directus"
DEV_DB_PASSWORD="your-dev-password-here"
DEV_DB_SSLMODE="require"
# Optional: Path to CA certificate file (for verify-ca or verify-full modes)
# DEV_DB_SSLCERT="/path/to/ca-certificate.crt"

# -----------------------------------------------------------------------------
# Production Environment (use with extreme caution!)
# -----------------------------------------------------------------------------
# Only fill these in if you really need production data locally
# Always use --sanitize flag when syncing from production
#
LIVE_DB_HOST="your-live-db-host.db.ondigitalocean.com"
LIVE_DB_PORT="25060"
LIVE_DB_NAME="directus"
LIVE_DB_USER="directus"
LIVE_DB_PASSWORD="your-live-password-here"
LIVE_DB_SSLMODE="require"
# Optional: Path to CA certificate file (for verify-ca or verify-full modes)
# LIVE_DB_SSLCERT="/path/to/ca-certificate.crt"
