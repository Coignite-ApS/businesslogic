{
  "name": "project-extension-stripe",
  "version": "1.0.0",
  "description": "Stripe billing, registration, and trial management for accounts",
  "type": "module",
  "directus:extension": {
    "type": "hook",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "test": "vitest run",
    "test:integration": "vitest run __tests__/refresh-quotas.integration.test.ts",
    "stripe:create-v2-products": "tsx scripts/create-products-v2.ts"
  },
  "dependencies": {
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.11",
    "@types/node": "^25.5.0",
    "knex": "^3.1.0",
    "pg": "^8.13.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
