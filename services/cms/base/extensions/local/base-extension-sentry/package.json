{
  "name": "base-extension-sentry",
  "version": "1.0.0",
  "description": "Sentry error tracking, performance monitoring, and health check for Directus",
  "type": "module",
  "directus:extension": {
    "type": "hook",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify"
  },
  "peerDependencies": {
    "@sentry/node": "^10.43.0",
    "@sentry/profiling-node": "^10.43.0"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
