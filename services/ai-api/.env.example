# ═══════════════════════════════════════════════════════════
# bl-ai-api — AI Chat, Knowledge Base, Embeddings Service
# ═══════════════════════════════════════════════════════════

# Core
PORT=3200
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://directus:directus@localhost:5432/directus

# Redis (BullMQ queues, caching, budget counters)
REDIS_URL=redis://localhost:6379

# ─── AI Providers ─────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Model Config ─────────────────────────────────────────
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_ALLOWED_MODELS=claude-sonnet-4-6,claude-haiku-4-5-20251001,claude-opus-4-6
AI_MAX_TOOL_ROUNDS=5
AI_MAX_OUTPUT_TOKENS=4096

# ─── Worker Pools ─────────────────────────────────────────
CHAT_POOL_SIZE=4
CHAT_TIMEOUT_MS=120000
EMBED_POOL_SIZE=2

# ─── Knowledge Base ───────────────────────────────────────
KB_EMBEDDING_MODEL=text-embedding-3-small
KB_CHUNK_SIZE=512
KB_CHUNK_OVERLAP=0.1
KB_CHUNK_MIN_SIZE=128
KB_CHUNK_MAX_SIZE=768
KB_MIN_SIMILARITY=0.2
KB_RRF_K=60
KB_CONTEXTUAL_RETRIEVAL=true
KB_ANSWER_CACHE_TTL=3600

# ─── Reranker (optional) ─────────────────────────────────
KB_RERANKER_ENABLED=false
KB_RERANKER_PROVIDER=cohere
KB_RERANKER_API_KEY=
KB_RERANKER_MODEL=
KB_RERANKER_TOP_K=10

# ─── BullMQ Ingestion ────────────────────────────────────
INGEST_CONCURRENCY=2
INGEST_RETRIES=3

# ─── Budget Enforcement ──────────────────────────────────
DAILY_BUDGET_USD=100
MONTHLY_BUDGET_USD=1000
GLOBAL_DAILY_BUDGET_USD=500
CONVERSATION_BUDGET_USD=1

# ─── Cache ────────────────────────────────────────────────
CACHE_MAX_ITEMS=10000
CACHE_TTL_SECONDS=300

# ─── Auth ─────────────────────────────────────────────────
AI_API_ADMIN_TOKEN=
TOKEN_ENCRYPTION_KEY=

# ─── External Services ───────────────────────────────────
FORMULA_API_URL=http://localhost:3000
FORMULA_API_ADMIN_TOKEN=

# ─── Conversations ────────────────────────────────────────
AI_MAX_CONVERSATION_MESSAGES=50
AI_MAX_CONVERSATIONS=50
AI_MAX_MESSAGE_LENGTH=10000

# ─── Rate Limiting ────────────────────────────────────────
AI_RATE_LIMIT_PER_MINUTE=20

# ─── Backpressure ─────────────────────────────────────────
REQUEST_TIMEOUT_MS=130000
MAX_EVENT_LOOP_DELAY_MS=1000
MAX_PAYLOAD_SIZE=52428800
REQUEST_LOGGING=false
