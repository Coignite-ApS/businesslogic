# ============================================================================
# BusinessLogic Flow Engine — Environment Variables
# Copy to .env and adjust for your environment.
# ============================================================================

# --- Database ---
DATABASE_URL=postgres://bl:bl_dev_password@localhost:5433/businesslogic

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Trigger Service ---
PORT=3100
# INSTANCE_ID=trigger-1

# --- Worker ---
# WORKER_GROUP=default
# CONCURRENCY=4

# --- Logging ---
RUST_LOG=info
# RUST_LOG=flow_trigger=debug,flow_worker=debug,flow_engine=trace

# --- Security ---
# WEBHOOK_HMAC_KEY=your-secret-key-here
# ADMIN_TOKEN=your-admin-token-here

# --- Observability ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=flow-engine

# --- Budget ---
# DEFAULT_BUDGET_LIMIT_USD=10.00
