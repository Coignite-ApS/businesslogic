{
  "dashboard": {
    "title": "BusinessLogic — Infrastructure",
    "uid": "bl-infra",
    "tags": ["businesslogic", "infrastructure"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage per Server",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "{{instance}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
      },
      {
        "id": 2,
        "title": "Memory Usage per Server",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
            "legendFormat": "{{instance}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
      },
      {
        "id": 3,
        "title": "PostgreSQL Active Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "{{datname}} ({{state}})"
          }
        ]
      },
      {
        "id": 4,
        "title": "Redis Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "redis_memory_used_bytes",
            "legendFormat": "used"
          },
          {
            "expr": "redis_memory_max_bytes",
            "legendFormat": "max"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "bytes" } }
      },
      {
        "id": 5,
        "title": "Disk Usage per Server",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100",
            "legendFormat": "{{instance}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
      },
      {
        "id": 6,
        "title": "Redis Commands per Second",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "rate(redis_commands_processed_total[5m])",
            "legendFormat": "cmd/s"
          }
        ]
      }
    ]
  }
}
