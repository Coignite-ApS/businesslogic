# =============================================================================
# BusinessLogic Platform — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env
#
# Values marked <REPLACE> MUST be filled in. Others have sensible defaults.
# See .env in the same directory for a working local example.
# =============================================================================

# ── Project ──────────────────────────────────────────────────────────
PROJECT_VERSION=1.0.0

# ── Directus Core ────────────────────────────────────────────────────
# KEY and SECRET: Random 32+ char strings for JWT signing and hashing.
# Generate: openssl rand -hex 32
KEY=<REPLACE-openssl-rand-hex-32>
SECRET=<REPLACE-openssl-rand-hex-32>
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ── Token Encryption (AES-256-GCM) ──────────────────────────────────
# Used by calculator-api extension to encrypt/decrypt API keys.
# Must be exactly 64 hex chars (32 bytes). Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=<REPLACE-openssl-rand-hex-32>

# ── NPM Token ───────────────────────────────────────────────────────
# Required for private @coignite packages during Docker builds.
# Get from: npm token create --read-only
NPM_TOKEN=<REPLACE-your-npm-token>

# ── Service Auth Tokens ─────────────────────────────────────────────
# Internal service-to-service authentication tokens.
FORMULA_API_ADMIN_TOKEN=dev-formula-token-change-in-production
# Only needed by bl-flow-trigger service (CMS now routes via gateway internal auth)
FLOW_TRIGGER_ADMIN_TOKEN=dev-flow-token-change-in-production
AI_API_ADMIN_TOKEN=dev-ai-token-change-in-production

# ── AI APIs ─────────────────────────────────────────────────────────
# Anthropic: AI chat assistant (Claude models)
ANTHROPIC_API_KEY=<REPLACE-sk-ant-your-key>
# OpenAI: Embeddings (text-embedding-3-small) for knowledge base
OPENAI_API_KEY=<REPLACE-sk-proj-your-key>

# ── AI Feature Flags ────────────────────────────────────────────────
# AI_SERVICE_ENABLED: Set to true to proxy AI/KB requests through gateway to bl-ai-api
AI_SERVICE_ENABLED=false
AI_ENABLED=true
AI_ASSISTANT_ENABLED=true

# ── AI API Host Port ───────────────────────────────────────────────
# Host port for bl-ai-api (container always listens on 3200)
AI_API_HOST_PORT=13200
AI_API_LOG_LEVEL=warn

# ── AI Configuration ────────────────────────────────────────────────
AI_DEFAULT_MODEL=claude-sonnet-4-6
AI_MAX_TOOL_ROUNDS=5
AI_MAX_CONVERSATION_MESSAGES=50
AI_RATE_LIMIT_PER_MINUTE=20

# ── Knowledge Base ──────────────────────────────────────────────────
KB_EMBEDDING_MODEL=text-embedding-3-small
KB_CHUNK_SIZE=512
KB_CHUNK_OVERLAP=0.1
KB_MIN_SIMILARITY=0.2
KB_RRF_K=60
KB_ANSWER_CACHE_TTL=3600
KB_CONTEXTUAL_RETRIEVAL=true
KB_RERANKER_ENABLED=false

# ── Stripe (Billing) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=<REPLACE-sk_test_your-key>
STRIPE_WEBHOOK_SECRET=<REPLACE-whsec_your-key>

# ── Gateway (CMS→gateway→services internal auth) ───────────────────
GATEWAY_INTERNAL_SECRET=dev-internal-secret-change-in-production

# ── Service URLs (internal Docker network) ──────────────────────────
FORMULA_API_URL=http://bl-formula-api:3000
FLOW_TRIGGER_URL=http://bl-flow-trigger:3100
AI_API_URL=http://bl-ai-api:3200

# ── Formula API ─────────────────────────────────────────────────────
FORMULA_PORT=3000
FORMULA_HOST=0.0.0.0
FORMULA_LOG_LEVEL=warn
FORMULA_REQUEST_LOGGING=true
POOL_SIZE=0
REQUEST_TIMEOUT_MS=60000
ENGINE=bl-excel
DEFAULT_LOCALE=enUS
CACHE_TTL_SECONDS=3600
CACHE_MAX_MEMORY_ITEMS=50000
MAX_QUEUE_DEPTH=0
MAX_HEAP_USED_BYTES=0
MAX_EVENT_LOOP_DELAY_MS=500
TEST_ACCOUNT_ID=8eeb078e-d01d-49db-859e-f30671ff9e53
FORMULA_TEST_TOKEN=6b24f3c3-c9fb-487c-8230-e28fcd5d36c1
MAX_PAYLOAD_SIZE=20MB

# ── Calculator Configuration ───────────────────────────────────────
CALCULATOR_TTL_SECONDS=1800
CALCULATOR_REDIS_TTL_SECONDS=86400
CALCULATOR_RESULT_TTL_SECONDS=3600
ACCOUNT_LIMITS_REDIS_TTL_SECONDS=86400
MAX_CALCULATORS_PER_WORKER=10
MAX_CALCULATORS=100

# ── Admin API (formula-api token validation) ───────────────────────
# Still used for calculator token validation (auth.js).
# Stats are now written directly to formula.calculator_calls via DATABASE_URL.
ADMIN_API_URL=http://bl-cms:8055
ADMIN_API_KEY=<REPLACE-directus-static-token>

# ── Formula API Direct DB ───────────────────────────────────────────
# formula-api reads calculator recipes and writes stats directly to PostgreSQL
# DATABASE_URL is shared with other services (same Directus DB)
# FORMULA_DATABASE_URL=postgresql://directus:directus@postgres:5432/directus
# (in docker-compose this is set as DATABASE_URL for bl-formula-api)

# ── Flow Engine ─────────────────────────────────────────────────────
FLOW_DATABASE_URL=postgres://directus:directus@postgres:5432/directus
FLOW_REDIS_URL=redis://redis:6379
FLOW_PORT=3100
RUST_LOG=info

# ── Sentry ──────────────────────────────────────────────────────────
# DE_SENTRY_DSN=https://...@sentry.coignite.dk/16
